# ── Database ─────────────────────────────────────────────────────────────────
# Replit PostgreSQL (or any Postgres connection string)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (no trailing /rest/v1)
SUPABASE_URL=https://your-project.supabase.co

# Anon key — safe for public clients
SUPABASE_ANON_KEY=your-supabase-anon-key

# Service-role key — KEEP SECRET, bypasses Row Level Security
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=a-long-random-string-at-least-32-chars
