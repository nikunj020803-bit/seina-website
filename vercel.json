{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/seina-website run build",
  "outputDirectory": "artifacts/seina-website/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
